{
  "author": "Eric Promislow",
  "manifest_version": 3,
  "name": "Done At Three",
  "short_name": "Done At Three",
  "version": "0.1.3",
  "description": "Automatically clicks the last four words in the NYT Connections Games (no affiliation)",
  "permissions": [],
  "host_permissions": ["https://www.nytimes.com/games/connections*"],
  "content_scripts": [
    {
      "matches": ["https://www.nytimes.com/games/connections*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
